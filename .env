# Ollama 本地配置（通过代理）
ANTHROPIC_BASE_URL=http://localhost:11435
ANTHROPIC_AUTH_TOKEN=sk-ollama-local

# 使用 Ollama 本地模型名称
ANTHROPIC_MODEL=qwen3:14b
ANTHROPIC_DEFAULT_SONNET_MODEL=qwen3:14b
ANTHROPIC_DEFAULT_HAIKU_MODEL=qwen3:14b
ANTHROPIC_DEFAULT_OPUS_MODEL=qwen3:14b

# 超时设置（毫秒）
API_TIMEOUT_MS=300000

# 禁用遥测和非必要网络请求
DISABLE_TELEMETRY=1
CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1
